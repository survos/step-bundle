{
    "name": "survos/step-bundle",
    "description": "Author steps as typed actions (Bash/Console/OpenUrl/DisplayCode/etc.) and render to README/Reveal/JSON.",
    "keywords": [
        "symfony-ux"
    ],
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": "^8.5",
        "symfony/http-kernel": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/config": "^8.1",
        "symfony/asset-mapper": "^8.1",
        "survos/jsonl-bundle": "^2.5",
        "symfony/framework-bundle": "^8.1",
        "survos/kit-bundle": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "Survos\\StepBundle\\": "src/"
        },
        "files": [
            "src/Runtime/functions.php"
        ]
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "symfony/panther": "^2.2"
    }
}